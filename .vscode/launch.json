    "version": "0.2.0",
    "configurations": [
        {
            "name": "a-service",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "run",
                    "--bin=a-service",
                    "--package=a-service"
                ]
            },
            "args": []
        },        
        {
            "name": "b-service",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "run",
                    "--bin=b-service",
                    "--package=b-service"
                ]
            },
            "args": []
        },
        {
            "name": "c-service",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "run",
                    "--bin=c-service",
                    "--package=c-service",
                    "--",
                    "--plugin-path", "${workspaceFolder}/target/debug",
                    "--plugin-cmdline", "--filename foo --is-happy"
                ]
            },
            "args": []
        }
    ]
}